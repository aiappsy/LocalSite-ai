# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter API (400+ models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic API (Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI API (Gemini models)
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# Mistral API
# MISTRAL_API_KEY=your_mistral_api_key_here

# Cerebras API (Fast inference)
# CEREBRAS_API_KEY=your_cerebras_api_key_here

# Custom OpenAI-compatible API (for other services like OpenAI, Together AI, Groq)
# OPENAI_COMPATIBLE_API_KEY=your_api_key_here
# OPENAI_COMPATIBLE_API_BASE=https://api.openai.com/v1
# Optional: If your provider does not support listing models, set a single model ID
# OPENAI_COMPATIBLE_MODEL=gpt-4

# Disable specific providers (comma-separated list)
# Example: DISABLED_PROVIDERS=ollama,lm_studio
# DISABLED_PROVIDERS=

# Default Provider (deepseek, openrouter, anthropic, google, mistral, cerebras, openai_compatible, ollama, lm_studio)
DEFAULT_PROVIDER=ollama

# Firebase Configuration (Required for Client-side Auth and DB)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# Coolify Deployment
# COOLIFY_URL=https://coolify.yourdomain.com
# COOLIFY_TOKEN=your_coolify_api_token